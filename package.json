{
  "name": "changelog-triage-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Monitor product changelogs for new entries, classify by severity (BREAKING/WARNING/INFO), and produce structured triage reports.",
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "apify": "^3.7.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@apify/tsconfig": "^0.1.1",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "tsx": "^4.20.3",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "start": "npm run start:dev",
    "start:prod": "node dist/main.js",
    "start:dev": "tsx src/main.ts",
    "build": "tsc",
    "test": "vitest run"
  },
  "author": "",
  "license": "ISC"
}
